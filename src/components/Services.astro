---
import { services } from "../data/services";
import ServiceCard from "./ServiceCard.astro";
---

<section id="services" class="py-24 md:py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="max-w-2xl mb-16">
      <p
        class="font-body text-xs tracking-[0.2em] uppercase text-text-muted mb-4"
      >
        What We Do
      </p>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-6">
        Deep expertise across the Ethereum stack
      </h2>
      <p class="font-body text-text-secondary leading-relaxed">
        From protocol design to production deployment, we bring hands-on
        experience shipping infrastructure at the core of Ethereum's ecosystem.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        services.map((service) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            icon={service.icon}
          />
        ))
      }
    </div>
  </div>
</section>

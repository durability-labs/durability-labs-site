---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="card-hover bg-surface-1 p-8 rounded-lg">
  <div class="service-icon mb-6" set:html={icon} />
  <h3 class="font-display text-lg font-semibold text-white mb-3">{title}</h3>
  <p class="font-body text-sm text-text-secondary leading-relaxed">
    {description}
  </p>
</div>

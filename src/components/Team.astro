---
import { team } from "../data/team";
import TeamCard from "./TeamCard.astro";
---

<section id="team" class="py-24 md:py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="max-w-2xl mb-16">
      <p
        class="font-body text-xs tracking-[0.2em] uppercase text-text-muted mb-4"
      >
        Our Team
      </p>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-6">
        Engineers who ship
      </h2>
      <p class="font-body text-text-secondary leading-relaxed">
        A tight-knit team with years of shared context building decentralized
        infrastructure together. Every member brings deep technical expertise and
        production experience.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        team.map((member) => (
          <TeamCard
            name={member.name}
            role={member.role}
            bio={member.bio}
            avatar={member.avatar}
            github={member.github}
            twitter={member.twitter}
          />
        ))
      }
    </div>
  </div>
</section>
